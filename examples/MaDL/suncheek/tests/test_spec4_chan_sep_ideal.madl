// ==========================================================================
// Channel Separation 方案验证 — 理想情况 (Snoop Channel 纯 child 流量)
// ==========================================================================
//
// 修复思路 (来自用户):
//   "Route L3-to-DDR ReadNoSnp over a completely separate channel
//    (e.g., forcing them onto the Snoop Channel via SnpReadNoSnp_Custom)"
//
// 本模型: 假设 Snoop Channel 只走 child ReadNoSnp,
//          不混入任何 parent snoop (SnpUnique/SnpQuery 等)
//
// 拓扑 (与 test_spec4_deadlock.madl 相同):
//
//   Core0 ──[Req Ch]──→ Router_mid ──[Req Ch]──→ L3_2 ←── Core0
//   Core8 ──[Req Ch]──→ Router_mid ──[Req Ch]──→ L3_0 ←── Core8
//
//   L3_0 miss → SnpReadNoSnp_Custom ──[Snp Ch]──→ DDR6
//   L3_2 miss → SnpReadNoSnp_Custom ──[Snp Ch]──→ DDR4
//
// 关键: Request Channel 和 Snoop Channel 使用独立的 VoQ 和 Credit
//       没有 Merge → 没有 parent/child 资源共享
//
// 期望结果: NO DEADLOCK (纯分离消除了依赖重叠)
// ==========================================================================

const tok;

param int VOQ_DEPTH = 2;       // §2.1.1
param int CREDIT_INIT = 5;     // §2.1.3
param int IRSR_DEPTH = 2;

macro CreditCounter(int n, chan consumed) => chan credit {
    chan q_in;
    let q_in, credit := Fork(PatientSource(tok));
    Sink(CtrlJoin(Queue(n, q_in), consumed));
};

// =====================================================================
// CPU Sources (parent requests)
// =====================================================================
chan core0_req := Source(tok);    // Core0 → L3_2 (East)
chan core8_req := Source(tok);    // Core8 → L3_0 (West)

// =====================================================================
// REQUEST CHANNEL — parent only (no child!)
//
// 与 deadlock 版的区别:
//   deadlock 版: voq_e = Merge(core0, l3_0_child) ← parent + child 混合
//   本版:        voq_e = core0 only             ← 纯 parent
// =====================================================================

// Req VoQ East: 仅 Core0 → L3_2 (parent)
chan req_voq_e := Queue(VOQ_DEPTH, core0_gated);
chan req_e_out, req_e_consumed := Fork(req_voq_e);
chan credit_req_e := CreditCounter(CREDIT_INIT, req_e_consumed);
chan core0_gated := CtrlJoin(core0_req, credit_req_e);

// Req VoQ West: 仅 Core8 → L3_0 (parent)
chan req_voq_w := Queue(VOQ_DEPTH, core8_gated);
chan req_w_out, req_w_consumed := Fork(req_voq_w);
chan credit_req_w := CreditCounter(CREDIT_INIT, req_w_consumed);
chan core8_gated := CtrlJoin(core8_req, credit_req_w);

// =====================================================================
// SNOOP CHANNEL — child ReadNoSnp only (理想分离)
//
// SnpReadNoSnp_Custom 走独立 Snoop Channel VoQ
// 独立 credit 池 → 与 Request Channel 完全解耦
// =====================================================================

// Snp VoQ East: L3_0 → DDR6 (SnpReadNoSnp_Custom, child only)
chan snp_voq_e := Queue(VOQ_DEPTH, l3_0_child_gated);
chan snp_e_out, snp_e_consumed := Fork(snp_voq_e);
chan credit_snp_e := CreditCounter(CREDIT_INIT, snp_e_consumed);

// Snp VoQ West: L3_2 → DDR4 (SnpReadNoSnp_Custom, child only)
chan snp_voq_w := Queue(VOQ_DEPTH, l3_2_child_gated);
chan snp_w_out, snp_w_consumed := Fork(snp_voq_w);
chan credit_snp_w := CreditCounter(CREDIT_INIT, snp_w_consumed);

// =====================================================================
// L3_2 (East side)
// Input: 仅从 Req Channel 接收 parent 请求
// Miss: SnpReadNoSnp 走 Snoop Channel (snp_voq_w) → 独立路径!
// =====================================================================
chan irsr_2 := Queue(IRSR_DEPTH, req_e_out);
chan hit_2, miss_2 := LoadBalancer(irsr_2);
Sink(hit_2);

chan child_2_tok, wait_2_tok := Fork(miss_2);
chan child_2_src := Source(tok);
chan l3_2_child := CtrlJoin(child_2_src, child_2_tok);
chan l3_2_child_gated := CtrlJoin(l3_2_child, credit_snp_w);

chan wait_2_q := Queue(IRSR_DEPTH, wait_2_tok);
chan done_2 := CtrlJoin(wait_2_q, ddr4_resp);
Sink(done_2);

// =====================================================================
// L3_0 (West side)
// =====================================================================
chan irsr_0 := Queue(IRSR_DEPTH, req_w_out);
chan hit_0, miss_0 := LoadBalancer(irsr_0);
Sink(hit_0);

chan child_0_tok, wait_0_tok := Fork(miss_0);
chan child_0_src := Source(tok);
chan l3_0_child := CtrlJoin(child_0_src, child_0_tok);
chan l3_0_child_gated := CtrlJoin(l3_0_child, credit_snp_e);

chan wait_0_q := Queue(IRSR_DEPTH, wait_0_tok);
chan done_0 := CtrlJoin(wait_0_q, ddr6_resp);
Sink(done_0);

// =====================================================================
// DDR4 — 从 Snoop Channel 接收 SnpReadNoSnp (独立于 Req Channel!)
// =====================================================================
chan ddr4_sink, ddr4_fwd := Fork(Queue(1, snp_w_out));
Sink(ddr4_sink);
chan ddr4_resp_src := Source(tok);
chan ddr4_resp := CtrlJoin(ddr4_resp_src, ddr4_fwd);

// =====================================================================
// DDR6
// =====================================================================
chan ddr6_sink, ddr6_fwd := Fork(Queue(1, snp_e_out));
Sink(ddr6_sink);
chan ddr6_resp_src := Source(tok);
chan ddr6_resp := CtrlJoin(ddr6_resp_src, ddr6_fwd);
