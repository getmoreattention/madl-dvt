// ==========================================================================
// Suncheek Protocol-Level Resource Deadlock — spec §4.0.2 精确场景
// ==========================================================================
//
//   物理拓扑 (1D 简化):
//
//     DDR4 ←── [voq_w_ddr4] ←── Router_mid ──→ [voq_e_ddr6] ──→ DDR6
//                                  |    |
//                            [voq_w]    [voq_e]
//                              |          |
//           Core8──→ L3_0 ←───┘          └───→ L3_2 ←── Core0
//
//   关键: Router_mid 的 voq_e 同时承载:
//     - Core0 → L3_2 的 parent request
//     - L3_0 → DDR6 的 child request (ReadNoSnp)
//   Router_mid 的 voq_w 同时承载:
//     - Core8 → L3_0 的 parent request
//     - L3_2 → DDR4 的 child request (ReadNoSnp)
//
//   死锁: voq_e 等 L3_2 释放 credit, 但 L3_2 IRSR 饱和等 DDR4 响应
//          voq_w 等 L3_0 释放 credit, 但 L3_0 IRSR 饱和等 DDR6 响应
//          → 循环等待
// ==========================================================================

const tok;

param int VOQ_DEPTH = 2;       // spec §2.1.1
param int CREDIT_INIT = 5;     // spec §2.1.3
param int IRSR_DEPTH = 2;      // 简化

macro CreditCounter(int n, chan consumed) => chan credit {
    chan q_in;
    let q_in, credit := Fork(PatientSource(tok));
    Sink(CtrlJoin(Queue(n, q_in), consumed));
};

// =====================================================================
// CPU Sources
// =====================================================================
chan core0_req := Source(tok);    // Core0 → L3_2 (East)
chan core8_req := Source(tok);    // Core8 → L3_0 (West)

// =====================================================================
// Router_mid 东向 Dedicated VoQ (req_voq_E)
//
// 同时承载:
//   - Core0 → L3_2  (parent, 东向)
//   - L3_0 → DDR6   (child, 东向)
//
// spec §4.0.2 step 3:
//   "L3_0's request lands in the East-bound VoQ (req_voq_E)"
//   "it needs a credit from the East"
//   "because L3_2 has blocked its input bus, no credits returned"
// =====================================================================
chan voq_e := Queue(VOQ_DEPTH, Merge(core0_gated, l3_0_child));

// Credit: L3_2 + DDR6 消费后释放 credit 给 voq_e 的上游
chan voq_e_out, voq_e_consumed := Fork(voq_e);
chan credit_e := CreditCounter(CREDIT_INIT, voq_e_consumed);
chan core0_gated := CtrlJoin(core0_req, credit_e);

// voq_e 输出路由到 L3_2 或 DDR6
chan to_l3_2, to_ddr6 := LoadBalancer(voq_e_out);

// =====================================================================
// Router_mid 西向 Dedicated VoQ (req_voq_W)
//
// 同时承载:
//   - Core8 → L3_0  (parent, 西向)
//   - L3_2 → DDR4   (child, 西向)
// =====================================================================
chan voq_w := Queue(VOQ_DEPTH, Merge(core8_gated, l3_2_child));

chan voq_w_out, voq_w_consumed := Fork(voq_w);
chan credit_w := CreditCounter(CREDIT_INIT, voq_w_consumed);
chan core8_gated := CtrlJoin(core8_req, credit_w);

chan to_l3_0, to_ddr4 := LoadBalancer(voq_w_out);

// =====================================================================
// L3_2 (East side)
//
// spec §4.0.2 step 1:
//   "Core0 sends a load that hits a DPB address hazard"
//   "IRSR fills up → L3_2 blocks its input bus"
// =====================================================================
chan irsr_2 := Queue(IRSR_DEPTH, to_l3_2);
chan hit_2, miss_2 := LoadBalancer(irsr_2);
Sink(hit_2);

// miss → generate ReadNoSnp to DDR4 (West)
chan child_2_tok, wait_2_tok := Fork(miss_2);
chan child_2_src := Source(tok);
chan l3_2_child := CtrlJoin(child_2_src, child_2_tok);

// Wait DDR4 response
chan wait_2_q := Queue(IRSR_DEPTH, wait_2_tok);
chan done_2 := CtrlJoin(wait_2_q, ddr4_resp);
Sink(done_2);

// =====================================================================
// L3_0 (West side)
//
// spec §4.0.2 step 1:
//   "Core8 sends a load that hits a DPB address hazard"
//   "IRSR fills up → L3_0 blocks its input bus"
// =====================================================================
chan irsr_0 := Queue(IRSR_DEPTH, to_l3_0);
chan hit_0, miss_0 := LoadBalancer(irsr_0);
Sink(hit_0);

// miss → generate ReadNoSnp to DDR6 (East)
chan child_0_tok, wait_0_tok := Fork(miss_0);
chan child_0_src := Source(tok);
chan l3_0_child := CtrlJoin(child_0_src, child_0_tok);

// Wait DDR6 response
chan wait_0_q := Queue(IRSR_DEPTH, wait_0_tok);
chan done_0 := CtrlJoin(wait_0_q, ddr6_resp);
Sink(done_0);

// =====================================================================
// DDR4 (West of L3_2)
// L3_2 child requests arrive via voq_w → LoadBalancer → to_ddr4
// =====================================================================
chan ddr4_sink, ddr4_fwd := Fork(Queue(1, to_ddr4));
Sink(ddr4_sink);
chan ddr4_resp_src := Source(tok);
chan ddr4_resp := CtrlJoin(ddr4_resp_src, ddr4_fwd);

// =====================================================================
// DDR6 (East of L3_0)
// L3_0 child requests arrive via voq_e → LoadBalancer → to_ddr6
// =====================================================================
chan ddr6_sink, ddr6_fwd := Fork(Queue(1, to_ddr6));
Sink(ddr6_sink);
chan ddr6_resp_src := Source(tok);
chan ddr6_resp := CtrlJoin(ddr6_resp_src, ddr6_fwd);
